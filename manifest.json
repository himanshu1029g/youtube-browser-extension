{
    "manifest_version": 3,
    "name": "youtube-browser-extension",
    "version": "1.0.0",
    "description": "Smart YouTube controls for students",
    "permissions": [
        "tabs",
        "scripting",
        "activeTab",
        "storage",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content_script.js"
            ],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    }
}